{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build && rm -rf api/ssr-assets && cp -r dist/client api/ssr-assets",
  "outputDirectory": "dist/client",
  "functions": {
    "api/ssr.ts": {
      "includeFiles": "api/ssr-assets/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/ssr?path=/$1"
    }
  ]
}
