{                                                                            
     "$schema": "https://openapi.vercel.sh/vercel.json",                        
     "buildCommand": "npm run build",                                           
     "functions": {                                                             
       "api/ssr.ts": {                                                          
         "includeFiles": "dist/client/**"                                       
       }                                                                        
     },                                                                         
     "routes": [                                                                
       {                                                                        
         "src": "/assets/(.*)",                                                 
         "dest": "/dist/client/assets/$1"                                       
       },                                                                       
       {                                                                        
         "src": "/(.*)",                                                        
         "dest": "/api/ssr?path=/$1"                                            
       }                                                                        
     ]                                                                          
   }