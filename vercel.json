{                                                                            
     "$schema": "https://openapi.vercel.sh/vercel.json",                        
     "buildCommand": "npm run build",                                           
     "functions": {                                                             
       "api/ssr.ts": {                                                          
         "includeFiles": "dist/client/**"                                       
       }                                                                        
     },                                                                         
     "rewrites": [                                                              
       {                                                                        
         "source": "/(.*)",                                                     
         "destination": "/api/ssr?path=/$1"                                     
       }                                                                        
     ]                                                                          
   } 